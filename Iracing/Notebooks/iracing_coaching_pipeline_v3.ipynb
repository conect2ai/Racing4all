    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "import matplotlib.ticker as mticker\n",
    "%matplotlib inline\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, clear_output\n",
    "\n",
    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# Helpers internos\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def _detect_braking_point(df, th=5.0):\n",
    "    \"\"\"Primeiro LapDistPct onde brake > th (escala 0-100 %).\"\"\"\n",
    "    mask = df[\"brake\"] > th\n",
    "    if not mask.any():\n",
    "        return None\n",
    "    return df.loc[mask.idxmax(), \"LapDistPct\"]\n",
    "\n",
    "\n",
    "def _detect_turning_point(df, steer_col, th_frac=0.15):\n",
    "    \"\"\"Primeiro LapDistPct onde |steering| > 15 % do pico do setor.\"\"\"\n",
    "    steer_abs = df[steer_col].abs()\n",
    "    peak = steer_abs.max()\n",
    "    if peak < 1e-3:\n",
    "        return None\n",
    "    mask = steer_abs > (peak * th_frac)\n",
    "    if not mask.any():\n",
    "        return None\n",
    "    return df.loc[mask.idxmax(), \"LapDistPct\"]\n",
    "\n",
    "\n",
    "def _vline_label(ax, x, label, color, ls, y_frac=0.90):\n",
    "    \"\"\"Linha vertical + caixinha de texto posicionada dinamicamente.\"\"\"\n",
    "    ax.axvline(x, color=color, ls=ls, lw=1.3, alpha=0.75, zorder=3)\n",
    "    ylim  = ax.get_ylim()\n",
    "    y_pos = ylim[0] + (ylim[1] - ylim[0]) * y_frac\n",
    "    ax.text(x, y_pos, label, fontsize=7, color=color,\n",
    "            ha='center', va='top', fontweight='bold', zorder=4,\n",
    "            bbox=dict(boxstyle='round,pad=0.2', fc='white',\n",
    "                      alpha=0.80, ec=color, lw=0.8))\n",
    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# Função principal\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def plot_sector_dna(interp_a, interp_b, sector_id,\n",
    "                    edges=CUSTOM_EDGES,\n",
    "                    label_a=None, label_b=None,\n",
    "                    gps_a=None,   gps_b=None):\n",
    "    \"\"\"\n",
    "    Plota comparação de DNA de pilotagem para um setor.\n",
    "\n",
    "    Parâmetros\n",
    "    ----------\n",
    "    interp_a, interp_b : dict ou DataFrame\n",
    "        Saída de align_lap_by_dist para cada piloto.\n",
    "    sector_id : int\n",
    "        Número do setor (1-indexed).\n",
    "    label_a, label_b : str, opcional\n",
    "        Nome dos pilotos nas legendas.\n",
    "        Default: usa DRIVER_REF / DRIVER_TEST do escopo do notebook.\n",
    "    gps_a, gps_b : DataFrame, opcional\n",
    "        DataFrame bruto da melhor volta de cada piloto (com Lat, Lon, LapDistPct).\n",
    "        Passe g_ref e g_test para ativar o mapa GPS.\n",
    "        Exemplo: plot_sector_dna(interp_A, interp_B, 7, gps_a=g_ref, gps_b=g_test)\n",
    "    \"\"\"\n",
    "\n",
    "    # ── 0. Nomes dos pilotos ──────────────────────────────────────────────\n",
    "    # Usa DRIVER_REF/DRIVER_TEST (nomes reais) — não driver_a/driver_b (aliases)\n",
    "    if label_a is None:\n",
    "        try:    label_a = DRIVER_REF\n",
    "        except NameError:\n",
    "            try:    label_a = driver_a\n",
    "            except NameError: label_a = \"Driver A\"\n",
    "\n",
    "    if label_b is None:\n",
    "        try:    label_b = DRIVER_TEST\n",
    "        except NameError:\n",
    "            try:    label_b = driver_b\n",
    "            except NameError: label_b = \"Driver B\"\n",
    "\n",
    "    COL_A, COL_B = '#1f77b4', '#d62728'\n",
    "\n",
    "    # ── 1. Conversão de segurança ─────────────────────────────────────────\n",
    "    if isinstance(interp_a, dict): interp_a = pd.DataFrame(interp_a)\n",
    "    if isinstance(interp_b, dict): interp_b = pd.DataFrame(interp_b)\n",
    "\n",
    "    # ── 2. Filtro de setor ────────────────────────────────────────────────\n",
    "    start_pct = edges[sector_id - 1]\n",
    "    end_pct   = edges[sector_id]\n",
    "\n",
    "    df_a = interp_a[(interp_a[\"LapDistPct\"] >= start_pct) &\n",
    "                    (interp_a[\"LapDistPct\"] <= end_pct)].copy()\n",
    "    df_b = interp_b[(interp_b[\"LapDistPct\"] >= start_pct) &\n",
    "                    (interp_b[\"LapDistPct\"] <= end_pct)].copy()\n",
    "\n",
    "    if df_a.empty or df_b.empty:\n",
    "        print(f\"⚠️  Setor {sector_id}: dados insuficientes.\")\n",
    "        return\n",
    "\n",
    "    sector_name = SECTOR_NAMES.get(sector_id, f\"Sector {sector_id}\")\n",
    "    steer_col   = (\"SteeringWheelAngle\"\n",
    "                   if \"SteeringWheelAngle\" in df_a.columns else \"steering\")\n",
    "\n",
    "    # ── 3. Eventos-chave ──────────────────────────────────────────────────\n",
    "    vmin_idx_a = df_a[\"speed\"].idxmin()\n",
    "    vmin_idx_b = df_b[\"speed\"].idxmin()\n",
    "    vmin_a  = df_a.loc[vmin_idx_a, \"speed\"]\n",
    "    vmin_x_a = df_a.loc[vmin_idx_a, \"LapDistPct\"]\n",
    "    vmin_b  = df_b.loc[vmin_idx_b, \"speed\"]\n",
    "    vmin_x_b = df_b.loc[vmin_idx_b, \"LapDistPct\"]\n",
    "\n",
    "    bp_a = _detect_braking_point(df_a)\n",
    "    bp_b = _detect_braking_point(df_b)\n",
    "    tp_a = _detect_turning_point(df_a, steer_col)\n",
    "    tp_b = _detect_turning_point(df_b, steer_col)\n",
    "\n",
    "    # ── 4. Layout com GridSpec ────────────────────────────────────────────\n",
    "    fig = plt.figure(figsize=(16, 20))\n",
    "    gs  = gridspec.GridSpec(\n",
    "        4, 2,\n",
    "        figure=fig,\n",
    "        height_ratios=[1.6, 1.0, 1.5, 0.9],\n",
    "        width_ratios=[1.0, 1.6],\n",
    "        hspace=0.42,\n",
    "        wspace=0.28\n",
    "    )\n",
    "\n",
    "    ax_gps   = fig.add_subplot(gs[0, 0])\n",
    "    ax_delta = fig.add_subplot(gs[0, 1])\n",
    "    ax_speed = fig.add_subplot(gs[1, :])\n",
    "    ax_pedal = fig.add_subplot(gs[2, :], sharex=ax_speed)\n",
    "    ax_steer = fig.add_subplot(gs[3, :], sharex=ax_speed)\n",
    "\n",
    "    fig.suptitle(\n",
    "        f\"DNA Analysis  ·  Sector {sector_id}: {sector_name}\\n\"\n",
    "        f\"Reference: {label_a}     Analysis: {label_b}\",\n",
    "        fontsize=13, fontweight='bold', y=0.995\n",
    "    )\n",
    "\n",
    "    # ── GPS MAP ───────────────────────────────────────────────────────────\n",
    "    if gps_a is not None and gps_b is not None:\n",
    "        # Filtra apenas o setor nos dados brutos\n",
    "        ga = gps_a[(gps_a[\"LapDistPct\"] >= start_pct) &\n",
    "                   (gps_a[\"LapDistPct\"] <= end_pct)].copy()\n",
    "        gb = gps_b[(gps_b[\"LapDistPct\"] >= start_pct) &\n",
    "                   (gps_b[\"LapDistPct\"] <= end_pct)].copy()\n",
    "\n",
    "        # Ordenar por posição na pista para garantir traçado contínuo\n",
    "        ga = ga.sort_values(\"LapDistPct\")\n",
    "        gb = gb.sort_values(\"LapDistPct\")\n",
    "\n",
    "        if not ga.empty and not gb.empty:\n",
    "            # Correção de aspecto lat/lon (1° lat ≈ 1° lon * cos(lat))\n",
    "            mid_lat  = np.radians(pd.concat([ga[\"Lat\"], gb[\"Lat\"]]).mean())\n",
    "            lon_scale = 1.0 / max(np.cos(mid_lat), 0.01)\n",
    "\n",
    "            ax_gps.plot(ga[\"Lon\"], ga[\"Lat\"],\n",
    "                        color=COL_A, lw=2.5, label=f\"{label_a} (Ref)\", zorder=2)\n",
    "            ax_gps.plot(gb[\"Lon\"], gb[\"Lat\"],\n",
    "                        color=COL_B, lw=2.5, ls='--', label=label_b, zorder=3)\n",
    "\n",
    "            # Marcador de início e fim do setor (usando piloto A como referência)\n",
    "            ax_gps.plot(ga[\"Lon\"].iloc[0],  ga[\"Lat\"].iloc[0],\n",
    "                        'o', ms=9, color='green', zorder=5,\n",
    "                        label=\"Sector In\")\n",
    "            ax_gps.plot(ga[\"Lon\"].iloc[-1], ga[\"Lat\"].iloc[-1],\n",
    "                        's', ms=9, color='black', zorder=5,\n",
    "                        label=\"Sector Out\")\n",
    "\n",
    "            ax_gps.set_aspect(lon_scale)\n",
    "            ax_gps.tick_params(labelsize=7)\n",
    "            ax_gps.legend(fontsize=7, loc='best')\n",
    "        else:\n",
    "            ax_gps.text(0.5, 0.5, \"GPS — sem dados\\npara este setor\",\n",
    "                        ha='center', va='center',\n",
    "                        transform=ax_gps.transAxes, fontsize=9)\n",
    "    else:\n",
    "        ax_gps.text(0.5, 0.5,\n",
    "                    \"Passe gps_a=g_ref\\ne gps_b=g_test\\npara ver o mapa\",\n",
    "                    ha='center', va='center',\n",
    "                    transform=ax_gps.transAxes, fontsize=9, color='gray')\n",
    "\n",
    "    ax_gps.set_title(f\"GPS Trace — Sector {sector_id}\", fontsize=10, fontweight='bold')\n",
    "    ax_gps.set_xlabel(\"Longitude\", fontsize=8)\n",
    "    ax_gps.set_ylabel(\"Latitude\", fontsize=8)\n",
    "    ax_gps.grid(True, alpha=0.25)\n",
    "\n",
    "    # ── DELTA TEMPO ───────────────────────────────────────────────────────\n",
    "    # t_rel = tempo desde o início da volta (ambos no mesmo grid de LapDistPct)\n",
    "    # delta positivo → B está mais lento naquela posição\n",
    "    n     = min(len(df_a), len(df_b))\n",
    "    t_a   = df_a[\"t_rel\"].values[:n]\n",
    "    t_b   = df_b[\"t_rel\"].values[:n]\n",
    "    lap_x = df_a[\"LapDistPct\"].values[:n]\n",
    "\n",
    "    dt_a     = t_a - t_a[0]          # tempo relativo desde entrada do setor\n",
    "    dt_b     = t_b - t_b[0]\n",
    "    delta_ms = (dt_b - dt_a) * 1000  # ms; positivo = B mais lento\n",
    "\n",
    "    ax_delta.axhline(0, color='gray', lw=0.8, ls=':', zorder=1)\n",
    "    ax_delta.fill_between(lap_x, 0, delta_ms,\n",
    "                          where=(delta_ms > 0),\n",
    "                          color=COL_B, alpha=0.28, label=f\"{label_b} slower\")\n",
    "    ax_delta.fill_between(lap_x, 0, delta_ms,\n",
    "                          where=(delta_ms <= 0),\n",
    "                          color=COL_A, alpha=0.28, label=f\"{label_b} faster\")\n",
    "    ax_delta.plot(lap_x, delta_ms, color='black', lw=1.8, zorder=3)\n",
    "\n",
    "    # Valor final do delta no canto\n",
    "    final_ms = delta_ms[-1]\n",
    "    sign_str = f\"+{final_ms:.0f}\" if final_ms >= 0 else f\"{final_ms:.0f}\"\n",
    "    ax_delta.text(0.98, 0.05, f\"Δ final: {sign_str} ms\",\n",
    "                  transform=ax_delta.transAxes,\n",
    "                  fontsize=9, ha='right', va='bottom', fontweight='bold',\n",
    "                  color=COL_B if final_ms > 0 else COL_A,\n",
    "                  bbox=dict(boxstyle='round,pad=0.3', fc='white', alpha=0.8, ec='gray'))\n",
    "\n",
    "    ax_delta.set_title(f\"Δ Time: {label_b} vs {label_a} (ms)\",\n",
    "                       fontsize=10, fontweight='bold')\n",
    "    ax_delta.set_xlabel(\"Lap Distance (%)\", fontsize=8)\n",
    "    ax_delta.set_ylabel(\"Δ Time (ms)\", fontsize=8)\n",
    "    ax_delta.tick_params(labelsize=7)\n",
    "    ax_delta.grid(True, alpha=0.25)\n",
    "    ax_delta.legend(fontsize=7, loc='upper left')\n",
    "\n",
    "    # ── VELOCIDADE ────────────────────────────────────────────────────────\n",
    "    ax_speed.plot(df_a[\"LapDistPct\"], df_a[\"speed\"],\n",
    "                  color=COL_A, lw=2.0, label=f\"{label_a} (Ref)\")\n",
    "    ax_speed.plot(df_b[\"LapDistPct\"], df_b[\"speed\"],\n",
    "                  color=COL_B, lw=2.0, ls='--', label=label_b)\n",
    "\n",
    "    speed_range = df_a[\"speed\"].max() - df_a[\"speed\"].min()\n",
    "    offset_v    = max(speed_range * 0.08, 2.0)\n",
    "\n",
    "    for vmin_x, vmin_v, col, lbl in [\n",
    "        (vmin_x_a, vmin_a, COL_A, label_a),\n",
    "        (vmin_x_b, vmin_b, COL_B, label_b),\n",
    "    ]:\n",
    "        ax_speed.plot(vmin_x, vmin_v, marker='v', ms=8, color=col, zorder=5)\n",
    "        ax_speed.annotate(\n",
    "            f\"Vmin {lbl[:4]}.\\n{vmin_v:.1f} km/h\",\n",
    "            xy=(vmin_x, vmin_v),\n",
    "            xytext=(vmin_x, vmin_v - offset_v * 1.8),\n",
    "            fontsize=7.5, color=col, fontweight='bold',\n",
    "            ha='center', va='top',\n",
    "            arrowprops=dict(arrowstyle='->', color=col, lw=1.0),\n",
    "            bbox=dict(boxstyle='round,pad=0.25', fc='white',\n",
    "                      alpha=0.80, ec=col, lw=0.8),\n",
    "            zorder=6,\n",
    "        )\n",
    "\n",
    "    ax_speed.set_ylabel(\"Speed (km/h)\", fontsize=10)\n",
    "    ax_speed.grid(True, alpha=0.25)\n",
    "    ax_speed.legend(loc='best', fontsize=9)\n",
    "    ax_speed.yaxis.set_minor_locator(mticker.AutoMinorLocator())\n",
    "    plt.setp(ax_speed.get_xticklabels(), visible=False)\n",
    "\n",
    "    # ── PEDAIS ────────────────────────────────────────────────────────────\n",
    "    ax_pedal.fill_between(df_a[\"LapDistPct\"], 0, df_a[\"brake\"],\n",
    "                          color=COL_A, alpha=0.10)\n",
    "    ax_pedal.plot(df_a[\"LapDistPct\"], df_a[\"brake\"],\n",
    "                  color=COL_A, lw=1.5, alpha=0.65,\n",
    "                  label=f\"Brake {label_a}\")\n",
    "\n",
    "    ax_pedal.fill_between(df_b[\"LapDistPct\"], 0, df_b[\"brake\"],\n",
    "                          color=COL_B, alpha=0.18)\n",
    "    ax_pedal.plot(df_b[\"LapDistPct\"], df_b[\"brake\"],\n",
    "                  color=COL_B, lw=2.0,\n",
    "                  label=f\"Brake {label_b}\")\n",
    "\n",
    "    ax_pedal.plot(df_a[\"LapDistPct\"], df_a[\"throttle\"],\n",
    "                  color=COL_A, lw=1.0, ls=':', alpha=0.55,\n",
    "                  label=f\"Throttle {label_a}\")\n",
    "    ax_pedal.plot(df_b[\"LapDistPct\"], df_b[\"throttle\"],\n",
    "                  color=COL_B, lw=1.0, ls=':', alpha=0.55,\n",
    "                  label=f\"Throttle {label_b}\")\n",
    "\n",
    "    ax_pedal.set_ylabel(\"Pedals (%)\", fontsize=10)\n",
    "    ax_pedal.set_ylim(-2, 110)\n",
    "    ax_pedal.grid(True, alpha=0.25)\n",
    "    ax_pedal.legend(loc='upper right', fontsize=7.5, ncol=2)\n",
    "    plt.setp(ax_pedal.get_xticklabels(), visible=False)\n",
    "\n",
    "    # Braking Point — escalonados verticalmente para não sobrepor\n",
    "    for i, (bp, col, lbl) in enumerate(\n",
    "            [(bp_a, COL_A, label_a), (bp_b, COL_B, label_b)]):\n",
    "        if bp is not None:\n",
    "            y_frac = 0.93 if i == 0 else 0.78\n",
    "            _vline_label(ax_pedal, bp, f\"BP\\n{lbl[:5]}.\",\n",
    "                         color=col, ls='--', y_frac=y_frac)\n",
    "\n",
    "    # ── VOLANTE ───────────────────────────────────────────────────────────\n",
    "    ax_steer.axhline(0, color='gray', lw=0.8, ls=':', zorder=1)\n",
    "    ax_steer.plot(df_a[\"LapDistPct\"], df_a[steer_col],\n",
    "                  color=COL_A, lw=1.5, alpha=0.65, label=label_a)\n",
    "    ax_steer.plot(df_b[\"LapDistPct\"], df_b[steer_col],\n",
    "                  color=COL_B, lw=1.5, label=label_b)\n",
    "\n",
    "    ax_steer.set_ylabel(\"Steering (rad)\", fontsize=10)\n",
    "    ax_steer.set_xlabel(\"Lap Distance (%)\", fontsize=10)\n",
    "    ax_steer.grid(True, alpha=0.25)\n",
    "    ax_steer.legend(loc='best', fontsize=9)\n",
    "\n",
    "    # Turning Point — escalonados verticalmente\n",
    "    for i, (tp, col, lbl) in enumerate(\n",
    "            [(tp_a, COL_A, label_a), (tp_b, COL_B, label_b)]):\n",
    "        if tp is not None:\n",
    "            y_frac = 0.93 if i == 0 else 0.78\n",
    "            _vline_label(ax_steer, tp, f\"TP\\n{lbl[:5]}.\",\n",
    "                         color=col, ls='-.', y_frac=y_frac)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ── Configuração do slider ────────────────────────────────────────────────────\n",
    "n_sectors = len(CUSTOM_EDGES) - 1\n",
    "\n",
    "slider = widgets.IntSlider(\n",
    "    value=9,\n",
    "    min=1,\n",
    "    max=n_sectors,\n",
    "    step=1,\n",
    "    description='Setor:',\n",
    "    continuous_update=False,       # só redesenha ao SOLTAR o slider (não enquanto arrasta)\n",
    "    style={'description_width': '55px'},\n",
    "    layout=widgets.Layout(width='55%')\n",
    ")\n",
    "\n",
    "lbl_sector = widgets.HTML(\n",
    "    value=f\"<b style='font-size:13px; color:#444'>\"\n",
    "          f\"{SECTOR_NAMES.get(slider.value, f'Setor {slider.value}')}</b>\",\n",
    "    layout=widgets.Layout(padding='5px 0 0 14px')\n",
    ")\n",
    "\n",
    "out = widgets.Output()\n",
    "\n",
    "# ── Callback ──────────────────────────────────────────────────────────────────\n",
    "def on_sector_change(change):\n",
    "    sid = change['new']\n",
    "    lbl_sector.value = (\n",
    "        f\"<b style='font-size:13px; color:#444'>\"\n",
    "        f\"{SECTOR_NAMES.get(sid, f'Setor {sid}')}</b>\"\n",
    "    )\n",
    "    with out:\n",
    "        clear_output(wait=True)   # limpa o plot anterior antes de renderizar\n",
    "        plt.close('all')          # libera memória das figuras antigas\n",
    "        plot_sector_dna(interp_A, interp_B, sid,\n",
    "                        gps_a=g_ref, gps_b=g_test)\n",
    "\n",
    "slider.observe(on_sector_change, names='value')\n",
    "\n",
    "# ── Layout ────────────────────────────────────────────────────────────────────\n",
    "header = widgets.HBox(\n",
    "    [slider, lbl_sector],\n",
    "    layout=widgets.Layout(\n",
    "        align_items='center',\n",
    "        padding='6px',\n",
    "        border='1px solid #ddd',\n",
    "        border_radius='6px',\n",
    "        margin='0 0 8px 0'\n",
    "    )\n",
    ")\n",
    "\n",
    "ui = widgets.VBox([header, out])\n",
    "\n",
    "# ── Render inicial (mostra o setor padrão sem precisar mover o slider) ────────\n",
    "with out:\n",
    "    plot_sector_dna(interp_A, interp_B, slider.value,\n",
    "                    gps_a=g_ref, gps_b=g_test)\n",
    "\n",
    "display(ui)\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# EXECUÇÃO\n",
    "# Passe gps_a=g_ref, gps_b=g_test para ativar o mapa GPS\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "#plot_sector_dna(interp_A, interp_B, sector_id=16,gps_a=g_ref, gps_b=g_test)"
   ]
