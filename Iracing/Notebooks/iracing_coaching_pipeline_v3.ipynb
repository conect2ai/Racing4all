    "        \"A4_THROTTLE_STEER_CONFLICT\",\n",
    "    ],\n",
    "    \"expert\": [r[\"id\"] for r in DRIVING_RULES],  # todas as regras\n",
    "}\n",
    "\n",
    "def filter_tips_by_level(tips: list, level: str) -> list:\n",
    "    allowed = set(RULES_BY_LEVEL.get(level, RULES_BY_LEVEL[\"expert\"]))\n",
    "    return [t for t in tips if t.get(\"id\", t.get(\"rule_id\", \"\")) in allowed]"
