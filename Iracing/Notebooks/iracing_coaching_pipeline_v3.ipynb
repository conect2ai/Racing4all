    "# ── Filtro de heurísticas por nível de piloto ──────────────────────\n",
    "# Iniciante recebe apenas erros macro (trajetória e ponto de frenagem)\n",
    "# Intermediário recebe frenagem + rotação + saída\n",
    "# Expert recebe tudo\n",
    "RULES_BY_LEVEL = {\n",
    "    \"amateur\": [\n",
    "        \"L1_EXIT_SPEED_LEGACY\",\n",
    "        \"B1_BRAKING_POINT_MISMATCH\",\n",
    "        \"ENTRY_OVER_SLOW\",\n",
    "        \"ENTRY_SPEED_TOO_LOW\",\n",
