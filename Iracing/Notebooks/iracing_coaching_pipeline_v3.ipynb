   "source": [
    "# ═══════════════════════════════════════════════════════════════\n",
    "# ANÁLISE ESTOCÁSTICA POR SETOR (ADF + KPSS + Entropia Shannon)\n",
    "# Requer: mínimo 8 voltas válidas no df_test\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "def compute_stochastic_state(series: np.ndarray) -> dict:\n",
    "    \"\"\"\n",
    "    Classifica o sinal de uma métrica (ex: Vmin volta a volta)\n",
    "    em 4 estados cognitivos usando ADF + KPSS.\n",
    "    \n",
    "    Retorna: state (S/TS/DS/NS), entropy, cognitive_label\n",
    "    \"\"\"\n",
    "    series = series[np.isfinite(series)]\n",
    "    if len(series) < 8:\n",
    "        return {\"state\": \"insufficient_data\",\n",
    "                \"entropy_level\": \"unknown\",\n",
    "                \"cognitive_label\": \"Dados insuficientes (mín. 8 voltas)\",\n",
    "                \"n\": len(series)}\n",
    "\n",
    "    # ADF: H0 = não-estacionário. p < 0.05 → rejeita H0 → É estacionário\n",
    "    try:\n",
    "        adf_p = adfuller(series, autolag='AIC')[1]\n",
    "        adf_rejects = adf_p < 0.05\n",
    "    except Exception:\n",
    "        adf_rejects = False\n",
    "\n",
    "    # KPSS: H0 = estacionário. p < 0.05 → rejeita H0 → NÃO é estacionário\n",
    "    try:\n",
    "        # suppress UserWarning sobre p-value interpolation\n",
    "        import warnings\n",
    "        with warnings.catch_warnings():\n",
    "            warnings.simplefilter(\"ignore\")\n",
    "            kpss_p = kpss(series, regression='c', nlags='auto')[1]\n",
    "        kpss_rejects = kpss_p < 0.05\n",
    "    except Exception:\n",
    "        kpss_rejects = False\n",
    "\n",
    "    # 4 estados cognitivos\n",
    "    if adf_rejects and not kpss_rejects:\n",
    "        state, label = \"S\",  \"Consistência fixada — risco de subdrive\"\n",
    "    elif not adf_rejects and not kpss_rejects:\n",
    "        state, label = \"TS\", \"Adaptação progressiva ativa (aprendizado)\"\n",
    "    elif adf_rejects and kpss_rejects:\n",
    "        state, label = \"DS\", \"Ajustes abruptos — explorando o limite\"\n",
    "    else:\n",
    "        state, label = \"NS\", \"Instabilidade crônica — sobrecarga cognitiva\"\n",
    "\n",
    "    # Entropia de Shannon sobre histograma (proxy de complexidade do sinal)\n",
    "    hist, _ = np.histogram(series, bins=min(10, len(series)//2 or 2), density=True)\n",
    "    hist = hist[hist > 0]\n",
    "    h = float(shannon_entropy(hist))\n",
    "    entropy_level = \"high\" if h > 2.0 else \"low\"\n",
    "\n",
    "    return {\n",
    "        \"state\": state,\n",
    "        \"entropy\": round(h, 3),\n",
    "        \"entropy_level\": entropy_level,\n",
    "        \"cognitive_label\": label,\n",
    "        \"n\": len(series)\n",
    "    }\n",
    "\n",
    "\n",
    "def compute_stochastic_profile(df, valid_laps, edges=CUSTOM_EDGES) -> dict:\n",
    "    \"\"\"\n",
    "    Coleta Vmin e BrakeStart por setor ao longo das N voltas válidas\n",
    "    e aplica compute_stochastic_state em cada setor.\n",
    "    \n",
    "    Retorna dict keyed por sector_id.\n",
    "    \"\"\"\n",
    "    grid_local = np.linspace(0.0, 1.0, 2000)\n",
    "    vmin_by_sec  = {i: [] for i in range(1, len(edges))}\n",
    "    brake_by_sec = {i: [] for i in range(1, len(edges))}\n",
    "\n",
    "    for lap in valid_laps:\n",
    "        g = df[df[\"Lap\"] == lap]\n",
    "        interp_lap = align_lap_by_dist(g, grid_local)\n",
    "        if not interp_lap:\n",
    "            continue\n",
    "\n",
    "        lap_dist = interp_lap[\"LapDistPct\"]\n",
    "        speed    = interp_lap[\"speed\"]\n",
    "        brake    = interp_lap[\"brake\"]\n",
    "\n",
    "        for i in range(len(edges) - 1):\n",
    "            mask = (lap_dist >= edges[i]) & (lap_dist < edges[i+1])\n",
    "            idx  = np.flatnonzero(mask)\n",
    "            if idx.size == 0:\n",
    "                continue\n",
    "            sl = slice(idx[0], idx[-1] + 1)\n",
    "\n",
    "            vmin_by_sec[i+1].append(float(np.min(speed[sl])))\n",
    "\n",
    "            b_sec  = brake[sl]\n",
    "            b_mask = b_sec > 5.0   # threshold em % (escala 0-100)\n",
    "            first_b = np.flatnonzero(b_mask)\n",
    "            if first_b.size:\n",
    "                brake_by_sec[i+1].append(float(lap_dist[sl][first_b[0]]))\n",
    "\n",
    "    profile = {}\n",
    "    for sid in range(1, len(edges)):\n",
    "        v = np.array(vmin_by_sec[sid])\n",
    "        b = np.array(brake_by_sec[sid])\n",
    "        profile[sid] = {\n",
    "            \"vmin\":        compute_stochastic_state(v),\n",
    "            \"brake_start\": compute_stochastic_state(b),\n",
    "            \"n_laps\":      len(v)\n",
    "        }\n",
    "    return profile\n",
    "\n",
    "\n",
    "# --- EXECUÇÃO ---\n",
    "# valid_laps já existe da célula validity_test\n",
    "stoch_profile = compute_stochastic_profile(df_test, valid_laps)\n",
    "\n",
    "# Preview dos setores com mais dados\n",
    "preview = {sid: v for sid, v in stoch_profile.items() if v[\"n_laps\"] >= 8}\n",
    "print(f\"Setores com dados suficientes (≥8 voltas): {len(preview)}/{len(stoch_profile)}\")\n",
    "for sid, p in list(preview.items())[:3]:\n",
    "    print(f\"  Setor {sid:2d} | Vmin state={p['vmin']['state']:2s} | \"\n",
    "          f\"Entropia={p['vmin']['entropy']:.2f} ({p['vmin']['entropy_level']}) | \"\n",
    "          f\"n={p['n_laps']} voltas\")"
   ]
