    "def _first_idx(mask: np.ndarray):\n",
    "    idx = np.flatnonzero(mask)\n",
    "    return int(idx[0]) if idx.size else None\n",
    "\n",
    "def _last_idx(mask: np.ndarray):\n",
    "    idx = np.flatnonzero(mask)\n",
    "    return int(idx[-1]) if idx.size else None"
