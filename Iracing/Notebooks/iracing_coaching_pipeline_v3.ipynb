    "from __future__ import annotations\n",
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from IPython.display import Markdown\n",
    "import ollama\n",
    "\n",
    "# %% 1. SYSTEM PROMPTS POR NÍVEL\n",
    "SYSTEM_PROMPTS = {\n",
    "    \"amateur\": \"\"\"\n",
    "Você é um coach de pilotagem para SimRacing. O piloto é INICIANTE.\n",
    "\n",
    "Regras de comunicação:\n",
    "- Linguagem simples, sem jargão técnico\n",
    "- Uma ação corretiva por curva, no máximo\n",
    "- Foco em: onde frear, onde acelerar, trajetória visual (apex)\n",
    "- NUNCA mencione slip angle, yaw, coeficientes de pneu\n",
    "- Use analogias cotidianas quando possível\n",
    "\n",
    "Formato:\n",
    "- \"### Curva X: [Nome] (Δt = +Y.YYYs)\"\n",
    "- 1 bullet com instrução clara e direta\n",
    "- Finalize com \"### Foco da Próxima Sessão\" com 1 prioridade única\n",
    "\"\"\",\n",
    "\n",
    "    \"intermediate\": \"\"\"\n",
    "Você é um coach de pilotagem para SimRacing. O piloto é INTERMEDIÁRIO.\n",
    "\n",
    "Regras de comunicação:\n",
    "- Terminologia técnica básica permitida (trail braking, apex, oversteer)\n",
    "- Foco em: consistência, sobreposição pedal, velocidade no apex, ramp rate do freio\n",
    "- Compare com a referência em termos percentuais quando possível\n",
    "- Aponte causa raiz, não só sintoma\n",
    "\n",
    "Formato:\n",
    "- \"### Curva X: [Nome] (Δt = +Y.YYYs)\"\n",
    "- 2 bullets: [1] causa técnica identificada, [2] correção específica\n",
    "- Inclua valores concretos: \"entrada 8 km/h mais rápida\", \"freio 15m antes\"\n",
    "- Finalize com \"### Resumo de Foco Técnico\" com 3 prioridades\n",
    "\"\"\",\n",
    "\n",
    "    \"expert\": \"\"\"\n",
    "Você é um coach de pilotagem para SimRacing. O piloto é EXPERIENTE.\n",
    "\n",
    "Regras de comunicação:\n",
    "- Linguagem de engenharia de pista: slip angle, weight transfer, Fy, yaw rate\n",
    "- Foco em: envelope do pneu, aproveitamento de grip (%), dinâmica de transferência de carga\n",
    "- Referencie os parâmetros estimados (Cf, Cr, slip angle) quando disponíveis no JSON\n",
    "- Identifique padrões de consistência entre voltas, não apenas erros isolados\n",
    "\n",
    "Formato:\n",
    "- \"### Curva X: [Nome] (Δt = +Y.YYYs)\"  \n",
    "- 2 bullets: [1] diagnóstico físico (o que acontece dinamicamente), [2] ajuste de execução ou setup\n",
    "- Se parâmetros PINN disponíveis: cite slip angle estimado e margem de grip\n",
    "- Finalize com \"### Análise de Padrão\" identificando tendência sistêmica da volta\n",
    "\"\"\"\n",
    "}\n",
    "\n",
    "# Instruções comuns a todos os níveis (não repetir em cada prompt)\n",
    "COMMON_INSTRUCTIONS = \"\"\"\n",
    "Instruções gerais:\n",
    "1) Dados JSON ordenados por magnitude de perda (maior → menor). MANTENHA esta ordem.\n",
    "2) Categoria 'Legado': explique que a perda é consequência da curva anterior, não erro atual.\n",
    "3) Use nomes oficiais das curvas (T7, Bus Stop, Oval T1).\n",
    "4) Se delta_time_s ≤ 0: escreva apenas \"Execução consistente com a referência.\"\n",
    "\"\"\"\n",
    "\n",
    "STOCHASTIC_INSTRUCTIONS = \"\"\"\n",
    "Interpretação do campo 'stochastic_context' no JSON:\n",
    "- vmin_state='S'  + delta > 0 → piloto PRESO NA ZONA DE CONFORTO (subdrive).\n",
    "  Diga que a execução é consistente mas conservadora. Sugira 1 passo concreto de risco.\n",
    "- vmin_state='TS' → adaptação progressiva em curso. Elogie e aponte próximo patamar.\n",
    "- vmin_state='DS' → ajustes abruptos entre voltas. Elogie a exploração, peça fluidez.\n",
    "- vmin_state='NS' ou entropy_level='high' → PRIORIDADE MÁXIMA: piloto em modo reativo.\n",
    "  Não liste outras heurísticas. Foco único: estabilizar inputs antes de buscar velocidade.\n",
    "- Se n_laps_analyzed < 8: ignore o stochastic_context e baseie-se apenas nas heurísticas.\n",
    "\"\"\"\n",
    "\n",
    "def get_system_prompt(level: str) -> str:\n",
    "    base = SYSTEM_PROMPTS.get(level, SYSTEM_PROMPTS[\"intermediate\"])\n",
    "    return (base.strip() + \"\\n\\n\"\n",
    "            + COMMON_INSTRUCTIONS.strip() + \"\\n\\n\"\n",
    "            + STOCHASTIC_INSTRUCTIONS.strip())\n",
    "\n",
    "# %% 2. FUNÇÕES DE SUPORTE AO PROMPT\n",
    "def _safe_float(x):\n",
    "    try:\n",
    "        if x is None: return None\n",
    "        x = float(x)\n",
    "        return x if np.isfinite(x) else None\n",
    "    except: return None\n",
    "\n",
    "\n",
    "def build_tips_payload_by_sector(\n",
    "    seg_cmp, sectors_dt, interp_B,\n",
    "    stochastic_profile: dict = None,   # ← NOVO: saída de compute_stochastic_profile\n",
    "    edges=CUSTOM_EDGES,\n",
    "    max_tips_per_sector=2,\n",
    "    loss_threshold=0.010,\n",
    "    pilot_level=\"intermediate\",\n",
    "    pinn_params: dict | None = None\n",
    ") -> dict:\n",
    "    payload = {\n",
    "        \"meta\": {\n",
    "            \"track\": TRACK_NAME,\n",
    "            \"pilot_level\": pilot_level,\n",
    "            \"note\": \"Setores ordenados por perda de tempo. Inclui diagnóstico estocástico.\"\n",
    "        },\n",
    "        \"sectors\": []\n",
    "    }\n",
    "\n",
    "    temp_sectors = []\n",
    "    for sid in seg_cmp[\"Sector\"].unique():\n",
    "        dt_row = sectors_dt.loc[sectors_dt[\"Sector\"] == sid, \"DeltaTime_s\"]\n",
    "        dt = _safe_float(dt_row.iloc[0]) if not dt_row.empty else 0.0\n",
    "        if dt > loss_threshold:\n",
    "            temp_sectors.append({\n",
    "                \"id\": int(sid), \"delta\": dt,\n",
    "                \"name\": SECTOR_NAMES.get(sid, f\"Setor {sid}\")\n",
    "            })\n",
    "\n",
    "    temp_sectors = sorted(temp_sectors, key=lambda x: x[\"delta\"], reverse=True)\n",
    "\n",
    "    for s_info in temp_sectors:\n",
    "        sid = s_info[\"id\"]\n",
    "        df_sector = seg_cmp[seg_cmp[\"Sector\"] == sid].copy()\n",
    "\n",
    "        # Tips filtradas pelo nível\n",
    "        raw_tips = generate_sector_tips(df_sector, max_tips=max_tips_per_sector)\n",
    "        tips = filter_tips_by_level(raw_tips, pilot_level)\n",
    "\n",
    "        tips_min = [{\"priority\": int(t.get(\"priority\", 3)),\n",
    "                     \"rule_id\": str(t.get(\"rule_id\", \"\")),\n",
    "                     \"category\": str(t.get(\"category\", \"Geral\")),\n",
    "                     \"message\": str(t.get(\"message\", \"\"))} for t in tips]\n",
    "\n",
    "        # Valores numéricos brutos (resolve o problema do intermediário)\n",
    "        row = df_sector.iloc[0] if not df_sector.empty else {}\n",
    "        numeric_context = {\n",
    "            \"brake_peak_pct\":      round(float(row.get(\"BrakePeak_B\", 0)), 1),\n",
    "            \"brake_peak_ref_pct\":  round(float(row.get(\"BrakePeak_A\", 0)), 1),\n",
    "            \"vmin_kph\":            round(float(row.get(\"Vmin_B\", 0)), 1),\n",
    "            \"vmin_ref_kph\":        round(float(row.get(\"Vmin_A\", 0)), 1),\n",
    "            \"speed_entry_kph\":     round(float(row.get(\"SpeedStart_B\", 0)), 1),\n",
    "            \"speed_entry_ref_kph\": round(float(row.get(\"SpeedStart_A\", 0)), 1),\n",
    "            \"trail_overlap_ratio\": round(float(row.get(\"TrailOverlap_B\", 0)), 3),\n",
    "            \"steer_rms\":           round(float(row.get(\"SteerRMS_B\", 0)), 3),\n",
    "        }\n",
    "\n",
    "        # Estado estocástico (NOVO)\n",
    "        stoch_context = {\"available\": False}\n",
    "        if stochastic_profile and sid in stochastic_profile:\n",
    "            sp = stochastic_profile[sid]\n",
    "            n  = sp.get(\"n_laps\", 0)\n",
    "            stoch_context = {\n",
    "                \"available\":       n >= 8,\n",
    "                \"n_laps_analyzed\": n,\n",
    "                \"vmin_state\":      sp[\"vmin\"].get(\"state\", \"unknown\"),\n",
    "                \"vmin_cognitive\":  sp[\"vmin\"].get(\"cognitive_label\", \"\"),\n",
    "                \"entropy_level\":   sp[\"vmin\"].get(\"entropy_level\", \"unknown\"),\n",
    "                \"brake_state\":     sp[\"brake_start\"].get(\"state\", \"unknown\"),\n",
    "            }\n",
    "\n",
    "        sector_entry = {\n",
    "            \"id\": sid,\n",
    "            \"name\": s_info[\"name\"],\n",
    "            \"delta_time_s\": round(s_info[\"delta\"], 3),\n",
    "            \"numeric_context\": numeric_context,\n",
    "            \"stochastic_context\": stoch_context,\n",
    "            \"tips\": tips_min\n",
    "        }\n",
    "\n",
    "        # PINN só para expert\n",
    "        if pinn_params and pilot_level == \"expert\":\n",
    "            if s_info[\"name\"] in pinn_params:\n",
    "                sector_entry[\"pinn_estimates\"] = pinn_params[s_info[\"name\"]]\n",
    "\n",
    "        payload[\"sectors\"].append(sector_entry)\n",
    "\n",
    "    return payload\n",
    "\n",
    "def build_user_prompt(payload: dict) -> str:\n",
    "    return (\n",
    "        \"Analise os dados de telemetria abaixo e gere o feedback de coaching.\\n\\n\"\n",
    "        f\"JSON DATA:\\n{json.dumps(payload, ensure_ascii=False, indent=2)}\"\n",
    "    )\n",
    "\n"
   ]
  },
