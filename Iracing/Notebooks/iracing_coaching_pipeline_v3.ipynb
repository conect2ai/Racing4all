    "def call_ollama_chat(model, system_prompt, user_prompt, temperature=0.1):\n",
    "    resp = ollama.chat(\n",
    "        model=model,\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": system_prompt},\n",
    "            {\"role\": \"user\",   \"content\": user_prompt},\n",
    "        ],\n",
    "        options={\"temperature\": float(temperature),\n",
    "                 \"num_predict\": 600,\n",
    "                 \"num_ctx\": 8192}   # ← evita truncamento silencioso\n",
    "    )\n",
    "    # Compatibilidade ollama-python v0.2+ (dataclass) e v0.1 (dict)\n",
    "    if hasattr(resp, \"message\"):\n",
    "        return resp.message.content\n",
    "    return resp[\"message\"][\"content\"]\n",
    "\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "# EXECUÇÃO FINAL v4\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "PILOT_LEVEL  = \"intermediate\"   # \"amateur\" | \"intermediate\" | \"expert\"\n",
    "OLLAMA_MODEL = \"gemma3:12b\"\n",
    "\n",
    "# stoch_profile já calculado na célula de análise estocástica\n",
    "payload = build_tips_payload_by_sector(\n",
    "    seg_cmp=seg_cmp,\n",
    "    sectors_dt=sectors_AB,\n",
    "    interp_B=interp_B,\n",
    "    stochastic_profile=stoch_profile,   # ← NOVO\n",
    "    edges=CUSTOM_EDGES,\n",
    "    pilot_level=PILOT_LEVEL\n",
    ")\n",
    "\n",
    "system_p = get_system_prompt(PILOT_LEVEL)\n",
    "user_p   = build_user_prompt(payload)\n",
    "\n",
    "print(f\"Nível: {PILOT_LEVEL} | Setores: {len(payload['sectors'])} | Modelo: {OLLAMA_MODEL}\")\n",
    "print(f\"Setores com contexto estocástico: \"\n",
    "      f\"{sum(1 for s in payload['sectors'] if s['stochastic_context'].get('available'))}\")\n",
    "\n",
    "final_markdown = call_ollama_chat(\n",
    "    model=OLLAMA_MODEL,\n",
    "    system_prompt=system_p,\n",
    "    user_prompt=user_p\n",
    ")\n",
    "display(Markdown(final_markdown))"
   ]
