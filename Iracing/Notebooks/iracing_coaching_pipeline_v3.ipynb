    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "def plot_and_save_sectors(df, lap_df, track_name=\"Summit Point\", edges=CUSTOM_EDGES, names=SECTOR_NAMES):\n",
    "    \n",
    "    # 1. Identificação Automática da Volta Mais Rápida VÁLIDA\n",
    "    valid_laps_list = lap_df[lap_df[\"Valid\"] == True][\"Lap\"].tolist()\n",
    "    \n",
    "    if not valid_laps_list:\n",
    "        print(\"Aviso: Nenhuma volta válida encontrada! Usando a volta mais longa como fallback.\")\n",
    "        valid_laps_list = df[\"Lap\"].unique()\n",
    "\n",
    "    df_valid = df[df[\"Lap\"].isin(valid_laps_list)]\n",
    "    lap_stats = df_valid.groupby(\"Lap\")[\"SessionTime\"].agg(lambda x: x.max() - x.min())\n",
    "    ref_lap = lap_stats.idxmin()\n",
    "    \n",
    "    # 2. Preparação dos Dados\n",
    "    g = df[df[\"Lap\"] == ref_lap].copy().sort_values(\"SessionTime\")\n",
    "   \n",
    "    if g[\"LapDistPct\"].max() > 1.5:\n",
    "        g[\"LapDistPct\"] /= 100.0\n",
    "        \n",
    "    g[\"Lat\"] = g[\"Lat\"].interpolate(method=\"linear\", limit_direction=\"both\")\n",
    "    g[\"Lon\"] = g[\"Lon\"].interpolate(method=\"linear\", limit_direction=\"both\")\n",
    "    g = g.dropna(subset=[\"Lat\", \"Lon\"])\n",
    "        \n",
    "    g[\"Sector\"] = np.clip(np.digitize(g[\"LapDistPct\"], edges, right=True), 1, len(edges)-1)\n",
    "    \n",
    "    # 3. Configuração do Mapa\n",
    "    # Paleta de cores mais profissional (Colorblind-friendly / Padrão de artigos)\n",
    "    ACADEMIC_COLORS = ['#1f77b4', '#ff7f0e'] # Azul e Laranja\n",
    "\n",
    "    # Ajustado para um formato mais vertical (retrato) com tamanho fixo\n",
    "    fig, ax = plt.subplots(figsize=(8, 10))\n",
    "    \n",
    "    # Fundo branco puro para melhor contraste no PDF do artigo\n",
    "    background_color = \"white\"  \n",
    "    ax.set_facecolor(background_color)   \n",
    "    fig.patch.set_facecolor(background_color) \n",
    "\n",
    "    n_sectors = len(edges) - 1\n",
    "    \n",
    "    for sid in sorted(g[\"Sector\"].unique()):\n",
    "        sector_data = g[g[\"Sector\"] == sid]\n",
    "        if sector_data.empty: continue\n",
    "        \n",
    "        color = ACADEMIC_COLORS[(sid - 1) % 2] # Alterna entre as duas cores\n",
    "        \n",
    "        # Desenha a linha da pista (sem label, pois não usaremos legenda)\n",
    "        ax.plot(sector_data[\"Lon\"], sector_data[\"Lat\"],\n",
    "                color=color, lw=7, alpha=1.0)\n",
    "        \n",
    "        # Adiciona o número do setor com fundo circular branco e texto preto\n",
    "        mid_idx = len(sector_data) // 2\n",
    "        ax.text(sector_data[\"Lon\"].iloc[mid_idx], sector_data[\"Lat\"].iloc[mid_idx],\n",
    "                str(sid), fontsize=12, weight='bold', color='black',\n",
    "                ha='center', va='center',\n",
    "                bbox=dict(boxstyle='circle,pad=0.3', facecolor='white', edgecolor='black', linewidth=1.5))\n",
    "\n",
    "    # 4. Estética e Título Dinâmico\n",
    "    ax.set_aspect('equal')\n",
    "    ax.set_title(f\"{track_name}\", fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # Oculta os ticks de latitude/longitude\n",
    "    ax.set_yticks([])  \n",
